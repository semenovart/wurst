# Upstash Redis (https://console.upstash.com → создать БД → REST API).
# Без этих переменных приложение работает на in-memory заглушке (данные живут до рестарта).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Секрет для админ-удаления пожеланий: DELETE /api/admin/wish/<id> с заголовком x-admin-key.
# Сгенерировать: openssl rand -hex 24
ADMIN_SECRET=

# Публичный URL сайта (для share-ссылок и OG). Локально: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
